# Production Environment Configuration Template
# For deployment on production servers
# IMPORTANT: Never commit this - it contains sensitive data

# ============================================================================
# FLASK APPLICATION SETTINGS
# ============================================================================

FLASK_ENV=production
DEBUG=False

# Generate a strong secret key:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-very-long-random-secure-key-here-at-least-32-characters

# Server configuration
HOST=0.0.0.0                    # Listen on all interfaces
PORT=5001

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# For production, consider using PostgreSQL instead of SQLite
# For now, specify an absolute path for SQLite
DATABASE_PATH=/var/lib/astro/jyotish_core.db

# ============================================================================
# OLLAMA AI & LLM CONFIGURATION
# ============================================================================

# Production Ollama server (could be local or remote)
OLLAMA_HOST=localhost              # or use hostname/IP of remote server
OLLAMA_PORT=11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=120

# For remote Ollama server over network:
# OLLAMA_HOST=ai-server.internal.company.com
# OLLAMA_PORT=11434

# ============================================================================
# API & WEB CONFIGURATION
# ============================================================================

# Production API base URL (with domain)
API_BASE_URL=https://astro.yourcompany.com

# Geolocation user agent
NOMINATIM_USER_AGENT=astro-jyotish-prod/1.0

# ============================================================================
# LOGGING
# ============================================================================

# Production logging - minimal for performance
LOG_LEVEL=WARNING
LOG_FILE=/var/log/astro/astro_jyotish.log

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable AI analysis
ENABLE_AI_ANALYSIS=True

# Enable knowledge updates (set to False to prevent modifications)
ENABLE_KNOWLEDGE_UPDATE=False

# ============================================================================
# CACHING
# ============================================================================

# Longer cache timeout for production
CACHE_TIMEOUT=86400              # 24 hours

# ============================================================================
# ADVANCED - REVERSE PROXY / LOAD BALANCER
# ============================================================================

# If behind reverse proxy (nginx, Apache)
# PROXY_TRUSTED_HOSTS=127.0.0.1,10.0.0.0/8
# FORCE_HTTPS=True

# ============================================================================
# OPTIONAL - EXTERNAL LLM SERVICES
# ============================================================================

# If using OpenAI instead of local Ollama:
# EXTERNAL_LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# If using Anthropic Claude:
# EXTERNAL_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# ============================================================================
# MONITORING & ALERTS
# ============================================================================

# Sentry for error tracking (optional)
# SENTRY_DSN=https://...@sentry.io/...

# NewRelic for APM (optional)
# NEW_RELIC_CONFIG_FILE=/etc/astro/newrelic.ini
