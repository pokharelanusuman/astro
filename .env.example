# Vedic Astrology Engine - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# FLASK APPLICATION SETTINGS
# ============================================================================

# Environment: development, production, testing
FLASK_ENV=development

# Enable debug mode (set to False in production)
DEBUG=True

# Flask secret key (generate one for production using: python -c "import secrets; print(secrets.token_hex(16))")
# IMPORTANT: Change this in production!
SECRET_KEY=dev-secret-key-change-in-production

# Server host and port
HOST=127.0.0.1
PORT=5001

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Database file path (SQLite)
DATABASE_PATH=./jyotish_core.db

# ============================================================================
# OLLAMA AI & LLM CONFIGURATION
# ============================================================================

# Ollama server hostname/IP
OLLAMA_HOST=localhost

# Ollama server port
OLLAMA_PORT=11434

# AI model to use (e.g., mistral, llama2, neural-chat)
OLLAMA_MODEL=mistral

# Timeout for AI requests (in seconds)
OLLAMA_TIMEOUT=120

# ============================================================================
# API & WEB CONFIGURATION
# ============================================================================

# Base URL for API endpoints
API_BASE_URL=http://127.0.0.1:5001

# Geolocation user agent for Nominatim
NOMINATIM_USER_AGENT=jyotish_engine_core_v2

# ============================================================================
# LOGGING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=/tmp/astro_jyotish.log

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable AI-powered astrological analysis
ENABLE_AI_ANALYSIS=True

# Enable knowledge base updates from AI responses
ENABLE_KNOWLEDGE_UPDATE=True

# ============================================================================
# CACHING
# ============================================================================

# Cache timeout in seconds (1 hour = 3600)
CACHE_TIMEOUT=3600

# ============================================================================
# ADVANCED OPTIONS (Optional)
# ============================================================================

# If using remote Ollama server, set this to its URL
# OLLAMA_REMOTE_URL=http://remote-server:11434

# If using external API instead of Ollama
# EXTERNAL_LLM_API_KEY=your-api-key-here
# EXTERNAL_LLM_PROVIDER=openai  # or anthropic, cohere, etc.
